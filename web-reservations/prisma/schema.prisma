generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_USER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENCY_USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
