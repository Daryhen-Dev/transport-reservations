generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Lookup tables ────────────────────────────────────────────────────────────

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocumentType {
  id          String      @id @default(cuid())
  name        String      @unique
  proveedores Proveedor[]
  passengers  Passenger[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model ReservationStatus {
  id                    String                 @id @default(cuid())
  name                  String                 @unique
  passengerReservations PassengerReservation[]
  cargoReservations     CargoReservation[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model ProveedorType {
  id          String      @id @default(cuid())
  name        String      @unique
  proveedores Proveedor[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ─── Entidades principales ────────────────────────────────────────────────────

model Agency {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  branches  Branch[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  users     User[]
  routes    Route[]
  trips     Trip[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(cuid())
  name     String
  email    String  @unique
  password String
  roleId   String
  role     Role    @relation(fields: [roleId], references: [id])

  // AGENCY_ADMIN → agencyId set, branchId null
  // SUCURSAL_USER → branchId set, agencyId null
  // SUPER_ADMIN   → both null
  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id])
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Country {
  id          String      @id @default(cuid())
  name        String      @unique
  nationality String
  code        String?     @unique
  proveedores Proveedor[]
  passengers  Passenger[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Route {
  id          String        @id @default(cuid())
  origin      String
  destination String
  branchId    String
  branch      Branch        @relation(fields: [branchId], references: [id])
  trips       Trip[]
  schedules   TripSchedule[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model TripSchedule {
  id        String   @id @default(cuid())
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id], onDelete: Cascade)
  time      String   // "HH:MM" — naive local time, e.g. "07:00"
  isActive  Boolean  @default(true)
  trips     Trip[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routeId, time])
  @@map("trip_schedules")
}

model Trip {
  id                    String                 @id @default(cuid())
  departureAt           DateTime
  routeId               String
  route                 Route                  @relation(fields: [routeId], references: [id])
  branchId              String
  branch                Branch                 @relation(fields: [branchId], references: [id])
  scheduleId            String?
  schedule              TripSchedule?          @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  passengerReservations PassengerReservation[]
  cargoReservations     CargoReservation[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Proveedor {
  id               String        @id @default(cuid())
  proveedorTypeId  String
  proveedorType    ProveedorType @relation(fields: [proveedorTypeId], references: [id])

  // PERSONA
  firstName      String?
  lastName       String?
  documentTypeId String?
  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
  documentNumber String?
  birthDate      DateTime?
  countryId      String?
  country        Country?      @relation(fields: [countryId], references: [id])

  // EMPRESA
  companyName String?
  taxId       String?
  contactName String?
  phone       String?

  passengerReservations PassengerReservation[]
  cargoReservations     CargoReservation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PassengerReservation {
  id                  String                 @id @default(cuid())
  tripId              String
  trip                Trip                   @relation(fields: [tripId], references: [id])
  proveedorId         String
  proveedor           Proveedor              @relation(fields: [proveedorId], references: [id])
  seatCount           Int
  reservationStatusId String
  reservationStatus   ReservationStatus      @relation(fields: [reservationStatusId], references: [id])
  passengers          ReservationPassenger[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model ReservationPassenger {
  reservationId String
  passengerId   String
  reservation   PassengerReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  passenger     Passenger            @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  @@id([reservationId, passengerId])
}

model Passenger {
  id             String                 @id @default(cuid())
  firstName      String
  lastName       String
  documentTypeId String
  documentType   DocumentType           @relation(fields: [documentTypeId], references: [id])
  documentNumber String
  birthDate      DateTime?
  phone          String?
  countryId      String
  country        Country                @relation(fields: [countryId], references: [id])
  reservations   ReservationPassenger[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([documentTypeId, documentNumber])
}

model CargoReservation {
  id                  String            @id @default(cuid())
  tripId              String
  trip                Trip              @relation(fields: [tripId], references: [id])
  proveedorId         String
  proveedor           Proveedor         @relation(fields: [proveedorId], references: [id])
  weightKg            Float
  diameterCm          Float?
  widthCm             Float?
  heightCm            Float?
  lengthCm            Float?
  reservationStatusId String
  reservationStatus   ReservationStatus @relation(fields: [reservationStatusId], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
